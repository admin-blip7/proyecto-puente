animation-case[data-v-1cfed3fc]::part(base-image) {
  width: 100%;
}
.product-card-container[data-v-4746af6a] {
  height: 100%;
  display: flex;
  flex-direction: column;
}
.product-card-container .banner-wrapper[data-v-4746af6a],
.product-card-container .fit-cover-image[data-v-4746af6a] {
  aspect-ratio: 1 / 1;
}
.product-card-container .banner-wrapper[data-v-4746af6a],
.product-card-container .banner-wrapper .fit-cover-image[data-v-4746af6a] {
  border-bottom-left-radius: 0px;
  border-bottom-right-radius: 0px;
}
.product-card-container .cta-wrapper[data-v-4746af6a] {
  flex: 1 0 0px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 16px;
  padding: 16px;
  word-break: break-word;
  border-top-left-radius: 0px;
  border-top-right-radius: 0px;
}
.product-card-container .cta-wrapper .item-title[data-v-4746af6a] {
  font-size: 26px;
  font-weight: 800;
  line-height: 1.2;
}
.product-card-container .cta-wrapper .item-subtitle[data-v-4746af6a] {
  font-size: 14px;
  font-weight: 500;
  margin-top: 16px;
  line-height: 1.2;
}
.product-card-container .cta-wrapper .cta-btn[data-v-4746af6a] {
  color: currentcolor;
  border-color: currentcolor;
}
@media (min-width: 992px) {
  .product-card-container .cta-wrapper[data-v-4746af6a] {
    gap: 32px;
  }
}
.listing-roll[data-v-f282e5c8] {
  padding: 8px 0px;
  display: grid;
  grid-template-columns: repeat(2, minmax(0px, 1fr));
}
.listing-roll .selection-entry[data-v-f282e5c8] {
  grid-column: 1 / -1;
  padding: 8px 16px;
}
@media (min-width: 768px) {
  .listing-roll[data-v-f282e5c8] {
    grid-template-columns: repeat(4, minmax(0px, 1fr));
  }
  .listing-roll .selection-entry[data-v-f282e5c8] {
    grid-column: auto;
  }
  .listing-roll.listing-view-list[data-v-f282e5c8]
    .listing-product-container
    .preview-image {
    width: 78%;
  }
}
@media (min-width: 992px) {
  .listing-roll .selection-entry[data-v-f282e5c8] {
    padding: 16px;
  }
}
p {
  margin-bottom: auto;
}
button {
  border: 1px solid transparent;
}
.full-width-offset {
  margin: 0px -16px;
}
.rounded-2xl {
  border-radius: 16px;
}
.fit-cover-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  vertical-align: middle;
}
.cta-btn {
  font-weight: 500;
  font-size: 16px;
  line-height: 1.2;
  text-align: center;
  border-radius: 40px;
  padding: 0px 20px;
  display: flex;
  align-items: center;
  width: fit-content;
  height: 40px;
  color: rgb(0, 0, 0);
  border: 1px solid rgb(0, 0, 0);
  cursor: pointer;
}
@media (min-width: 768px) {
  .full-width-offset {
    margin: 0px -32px;
  }
}

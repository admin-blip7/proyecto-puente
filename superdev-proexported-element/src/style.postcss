a:focus {
  outline: thin dotted;
}
a:active,
a:hover {
  outline: 0;
}
b {
  font-weight: bold;
}
img {
  border: 0;
}
button {
  font-family: inherit;
  font-size: 100%;
  margin: 0;
}
button {
  line-height: normal;
}
button {
  -webkit-appearance: button;
  cursor: pointer;
}
button::-moz-focus-inner {
  border: 0;
  padding: 0;
}
* {
  box-sizing: border-box;
}
div,
p {
  margin: 0;
  padding: 0;
}
a {
  text-decoration: none;
  color: #333;
}
p {
  margin-bottom: 22px;
}
